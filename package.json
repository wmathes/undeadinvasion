{
  "name": "@tailstorm/undeadinvasion",
  "description": "Undead Invasion - modernized from the original 2013 university project.",
  "private": false,
  "type": "module",
  "license": "UNLICENSED",
  "homepage": "https://github.com/wmathes/undeadinvasion#readme",
  "bugs": "https://github.com/wmathes/undeadinvasion/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wmathes/undeadinvasion.git"
  },
  "bin": {
    "undeadinvasion": "bin/undeadinvasion.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "IDEAS.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun --bun run --hot ./src/server.ts",
    "build": "bun build ./index.html --outdir=dist --minify --sourcemap=linked --target=browser --asset-naming='[name]-[hash].[ext]'",
    "postbuild": "bun run scripts/copy-assets.ts",
    "preview": "bun run src/server.ts --dist",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci"
  },
  "dependencies": {
    "pixi-viewport": "^6.0.3",
    "pixi.js": "8.18.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "sass": "^1.77.0",
    "semantic-release": "^24.2.1",
    "typescript": "^5.4.0"
  },
  "patchedDependencies": {
    "pixi.js@8.18.1": "patches/pixi.js@8.18.1.patch"
  }
}
